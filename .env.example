# Public URL after deploy (HTTPS required for Telegram Mini App + YooKassa return URL)
NEXT_PUBLIC_APP_URL=https://finance2-36rh.vercel.app

# ЮKassa (ЮMoney) — https://yookassa.ru/
# Shop ID and Secret Key from Merchant Profile → Integration → API keys
# Aliases YUKASSA_* are also supported
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Required when online cash register (54-FZ) is enabled in YooKassa:
# YOOKASSA_RECEIPT_EMAIL=support@your-domain.ru
# YOOKASSA_VAT_CODE=1
# YOOKASSA_TAX_SYSTEM_CODE=2

# Webhook URL to set in YooKassa dashboard:
# https://your-app.vercel.app/api/payments/webhook
# Events: payment.succeeded

# Optional: Telegram bot token for subscription notifications
# TELEGRAM_BOT_TOKEN=

# Optional: Upstash/Vercel KV for server-side subscription storage (production)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Secret for Vercel Cron (/api/cron/subscription-renewals)
# CRON_SECRET=

# Secret for admin panel (/admin?key=...), support, analytics, and message campaigns
# Falls back to CRON_SECRET if not set
# ADMIN_SUPPORT_SECRET=

# Comma-separated Telegram usernames that receive a test subscription on app open
# TEST_GRANT_SUBSCRIPTION_USERNAMES=dinnetta
